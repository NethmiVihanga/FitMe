<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.FitMe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="fontFamily">serif</item>
        <item name="colorControlActivated">#3251C4</item>
        <item name="colorAccent">#3251C4</item>
    </style>

    <style name="Theme.FitMe.Auth" parent="Theme.FitMe">
        <item name="android:statusBarColor">@color/gradient_end</item>
        <item name="android:windowBackground">@drawable/bg_gradient</item>
    </style>

    <!-- Input fields on gradient background -->
    <style name="Widget.FitMe.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/white</item>
        <item name="hintTextColor">@color/input_hint</item>
        <item name="android:textColorHint">@color/input_hint</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="shapeAppearanceOverlay">@style/ShapeCornerRound</item>
    </style>

    <style name="ShapeCornerRound">
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Primary button -->
    <style name="Widget.FitMe.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="fontFamily">@font/poppins_bold</item>
    </style>

    <!-- Card style -->
    <style name="Widget.FitMe.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Status bar transparent for splash -->
    <style name="Theme.FitMe.Splash" parent="Theme.FitMe">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowBackground">@drawable/bg_gradient</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.FitMe.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.FitMe.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/text_dark</item>
    </style>

    <style name="TextAppearance.FitMe.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/text_medium</item>
    </style>

    <style name="CustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="RoundedTopCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
