<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="#BFDBFE"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Row: Icon + Name + Status Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Circle Icon -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/icon_container"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="12dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/iv_design"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                    <ImageView
                        android:id="@+id/iv_placeholder_icon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/primary"
                        android:padding="12dp"
                        android:visibility="visible" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_order_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Custom Order"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_tailor_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="by Seamstress"
                    android:textColor="@color/text_header"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tv_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/bg_white_pill"
                android:backgroundTint="@color/white"
                android:textColor="@color/primary"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_chat"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/primary" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#8AA8E8"
            android:layout_marginBottom="12dp" />

        <!-- Quote Box -->
        <LinearLayout
            android:id="@+id/layout_quote_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_white_pill"
            android:backgroundTint="#8AA8E8"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="@color/white"
                android:layout_marginEnd="10dp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seamstress Quoted Price"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs. 0"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_white_pill"
                android:backgroundTint="#FF5252"
                android:text="Delete"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:elevation="2dp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_resend"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_white_pill"
                android:backgroundTint="#3251C4"
                android:text="Resend"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingHorizontal="16dp"
                android:elevation="2dp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_action"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_white_pill"
                android:backgroundTint="@color/primary"
                android:text="Track Order"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingHorizontal="24dp"
                android:elevation="2dp"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Hidden fields needed by adapter -->
        <TextView android:id="@+id/tv_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_order_date" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
