<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- Top Header (Back Button and Chat) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="32dp">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle_primary"
                    android:backgroundTint="@color/primary"
                    android:src="@drawable/ic_back_chevron"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tailor Profile"
                    android:textColor="@color/text_header"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_centerInParent="true" />

                <ImageButton
                    android:id="@+id/btn_chat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle_primary"
                    android:backgroundTint="@color/primary"
                    android:src="@android:drawable/sym_action_email"
                    app:tint="@color/white" />
            </RelativeLayout>

            <!-- Profile Info (Avatar + Details) Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#8AA8E8"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- Circular Avatar -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="50dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/white"
                        app:cardBackgroundColor="#BFDBFE"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="16dp">
                        <ImageView
                            android:id="@+id/iv_tailor_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_myplaces" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_tailor_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sarah Johnson"
                        android:textColor="@color/text_header"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_tailor_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Professional Seamstress"
                        android:textColor="@color/text_header"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_white_pill"
                        android:backgroundTint="#BFDBFE"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@android:drawable/btn_star_big_on"
                            app:tint="#F59E0B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 4.9 (127 reviews)"
                            android:textColor="@color/text_header"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Years Exp -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#BFDBFE"
                    app:cardElevation="0dp"
                    android:layout_marginEnd="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8+"
                            android:textColor="@color/primary"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tv_years_exp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Years Exp"
                            android:textColor="@color/text_header"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Projects -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#BFDBFE"
                    app:cardElevation="0dp"
                    android:layout_marginHorizontal="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="350"
                            android:textColor="@color/primary"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tv_projects"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Projects"
                            android:textColor="@color/text_header"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- On Time -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#BFDBFE"
                    app:cardElevation="0dp"
                    android:layout_marginStart="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="95%"
                            android:textColor="@color/primary"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tv_on_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="On Time"
                            android:textColor="@color/text_header"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ABOUT Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#BFDBFE"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About"
                        android:textColor="@color/text_header"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:layout_marginBottom="12dp" />
                    
                    <TextView
                        android:id="@+id/tv_about"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Experienced seamstress specializing in custom dresses, formal wear, and alterations. I take pride in creating beautiful, well-fitted garments tailored to your unique style."
                        android:textColor="@color/text_header"
                        android:lineSpacingExtra="4dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_specialties"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="4dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_dialog_map"
                            app:tint="@color/primary"
                            android:layout_marginEnd="8dp" />
                        
                        <TextView
                            android:id="@+id/tv_tailor_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Colombo, Sri Lanka"
                            android:textColor="@color/text_header"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Price List Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#BFDBFE"
                app:cardElevation="0dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Price List"
                        android:textColor="@color/text_header"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Simple Dress" android:textSize="14sp" android:textColor="@color/text_header" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rs. 3500" android:textSize="14sp"
                            android:textColor="@color/primary" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Formal Dress" android:textSize="14sp" android:textColor="@color/text_header" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rs. 6000" android:textSize="14sp"
                            android:textColor="@color/primary" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bridal Gown" android:textSize="14sp" android:textColor="@color/text_header" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rs. 15000+" android:textSize="14sp"
                            android:textColor="@color/primary" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Alterations" android:textSize="14sp" android:textColor="@color/text_header" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rs. 1500+" android:textSize="14sp"
                            android:textColor="@color/primary" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reviews Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reviews"
                android:textColor="@color/text_header"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_reviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="32dp" />

            <!-- Place Order Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_place_order"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_white_pill"
                android:backgroundTint="@color/primary"
                android:text="Place Order"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:elevation="4dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
