<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical">

    <!-- Unified Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="20dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:background="@drawable/bg_circle_primary"
            android:backgroundTint="@color/primary"
            android:src="@drawable/ic_back_chevron"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_centerInParent="true">
            <TextView
                android:id="@+id/tv_chat_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Chat"
                android:textColor="@color/text_header"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_chat_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Online"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Search bar (visible in list mode) -->
    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_white_pill"
        android:backgroundTint="#BFDBFE"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="10dp"
        android:hint="Search conversations..."
        android:paddingHorizontal="16dp"
        android:textColorHint="@color/primary"
        android:textColor="@color/text_header"
        android:textSize="14sp" />

    <!-- Messages List -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/tv_empty_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No messages yet"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Message Input Container (WhatsApp Style) -->
    <LinearLayout
        android:id="@+id/layout_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp"
        android:paddingTop="4dp"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_white_pill"
            android:backgroundTint="@color/white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:minHeight="48dp">

            <ImageButton
                android:id="@+id/btn_attach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/primary" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Message"
                android:maxLines="4"
                android:paddingHorizontal="8dp"
                android:paddingVertical="10dp"
                android:textColor="@color/text_header"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/btn_camera"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/primary" />
        </LinearLayout>

        <View android:layout_width="4dp" android:layout_height="1dp" />

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_primary"
                android:backgroundTint="@color/primary"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white"
                android:padding="12dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_primary"
                android:backgroundTint="@color/primary"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/white"
                android:padding="12dp" />
        </FrameLayout>
    </LinearLayout>

</LinearLayout>
