<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_primary"
            android:backgroundTint="@color/primary"
            android:src="@drawable/ic_back_chevron"
            app:tint="@color/white"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="My Orders"
            android:textColor="@color/text_header"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="24dp">
        <LinearLayout
            android:id="@+id/tab_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tab_all" android:layout_width="wrap_content" android:layout_height="40dp" android:text="All" android:background="@drawable/bg_white_pill" android:backgroundTint="@color/primary" android:gravity="center" android:paddingHorizontal="24dp" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginEnd="12dp" />
            <TextView android:id="@+id/tab_pending" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Pending" android:background="@drawable/bg_white_pill" android:backgroundTint="#BFDBFE" android:gravity="center" android:paddingHorizontal="24dp" android:textSize="12sp" android:textColor="@color/text_header" android:textStyle="bold" android:layout_marginEnd="12dp" />
            <TextView android:id="@+id/tab_completed" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Completed" android:background="@drawable/bg_white_pill" android:backgroundTint="#BFDBFE" android:gravity="center" android:paddingHorizontal="24dp" android:textSize="12sp" android:textColor="@color/text_header" android:textStyle="bold" android:layout_marginEnd="12dp" />
            <TextView android:id="@+id/tab_in_progress" android:layout_width="wrap_content" android:layout_height="40dp" android:text="In Progress" android:background="@drawable/bg_white_pill" android:backgroundTint="#BFDBFE" android:gravity="center" android:paddingHorizontal="24dp" android:textSize="12sp" android:textColor="@color/text_header" android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_orders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="20dp" />

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="No orders found"
        android:textColor="@color/text_header"
        android:textSize="16sp"
        android:fontFamily="serif"
        android:visibility="gone" />

</LinearLayout>
