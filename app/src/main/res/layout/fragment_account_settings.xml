<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_primary"
        android:backgroundTint="#3B82F6"
        android:src="@drawable/ic_back_chevron"
        android:tint="@color/white"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Account Settings"
        android:textColor="#3251C4"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="40dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERSONAL DETAILS"
                android:textColor="#3251C4"
                android:textStyle="bold"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#3251C4"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_white"
                android:hint="Full Name"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:textSize="14sp"
                android:inputType="textPersonName" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textColor="#3251C4"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_white"
                android:hint="Phone Number"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:textSize="14sp"
                android:inputType="phone"
                android:maxLength="10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textColor="#3251C4"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_location"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_white"
                android:hint="Location"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="32dp"
                android:textSize="14sp"
                android:inputType="text" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_white_pill"
                android:backgroundTint="#3B82F6"
                android:text="Save Changes"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginBottom="32dp" />

            <TextView
                android:id="@+id/btn_reset_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚠️ Reset All Database Data"
                android:textColor="#EF4444"
                android:textSize="11sp"
                android:padding="8dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
