<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Dress Preview Image (3D model) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@android:color/white">

                <ImageView
                    android:id="@+id/iv_dress_preview"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:alpha="0.3"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your image will show here"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:fontFamily="serif" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload a design to get started"
                    android:textColor="#C4C4C4"
                    android:textSize="11sp"
                    android:fontFamily="serif" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Upgrade Now Button -->
        <Button
            android:id="@+id/btn_upgrade_now_dress"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Upgrade Now – $9.99/month"
            android:textColor="@android:color/white"
            android:backgroundTint="#9C59E0"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="serif"
            android:layout_marginBottom="10dp" />

        <!-- Generate Dress Button -->
        <Button
            android:id="@+id/btn_generate_dress"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Generate 3D Sewing Dress"
            android:textColor="#1E3A5F"
            android:backgroundTint="@android:color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="serif"
            android:layout_marginBottom="14dp" />

        <!-- Upload Design Image Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:id="@+id/layout_upload_dress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#EAF4FB">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_upload"
                    app:tint="#5BA4CE"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Design Image"
                    android:textColor="#1E3A5F"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:fontFamily="serif" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI will analyze your design"
                    android:textColor="#5BA4CE"
                    android:textSize="11sp"
                    android:fontFamily="serif" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Contact Tailor -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_contact_tailor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="#EAF4FB">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_call"
                    app:tint="#5BA4CE"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Make it better, Contact Tailor"
                    android:textColor="#5BA4CE"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="serif" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Upgrade to Pro Banner -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#9C59E0">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upgrade to Pro"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unlock AI-powered 3D sewing patterns and advanced features for beginners"
                    android:textColor="#EDE9FE"
                    android:textSize="11sp"
                    android:fontFamily="serif"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Generate unlimited 3D sewing blocks\n• AI-assisted pattern recommendations\n• Step-by-step sewing guides\n• Priority customer support"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:fontFamily="serif"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
