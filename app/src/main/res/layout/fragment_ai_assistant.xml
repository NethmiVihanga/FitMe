<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FF5BA4CE">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back_chevron"
            android:background="@drawable/bg_circle_primary"
            android:padding="6dp"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Assistant"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:gravity="center" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/btn_star_big_on"
            app:tint="#F59E0B" />
    </LinearLayout>

    <!-- Tab Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#E8F4FD">

        <TextView
            android:id="@+id/tab_sewing_block"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🧩 Sewing Block"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#1E3A5F"
            android:background="#5BA4CE" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#AACCEE" />

        <TextView
            android:id="@+id/tab_sewing_dress"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="👗 Sewing Dress"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#1E3A5F"
            android:background="#D1E9F8" />
    </LinearLayout>

    <!-- Content Pager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewpager_ai"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
