<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Avatar + Name/Rating/Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Circular Avatar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="68dp"
                android:layout_height="68dp"
                app:cardCornerRadius="34dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#EFF6FF"
                app:cardElevation="0dp"
                android:layout_marginEnd="16dp">
                <ImageView
                    android:id="@+id/iv_tailor_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_dress" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Info Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_tailor_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sarah Johnson"
                    android:textColor="#0F172A"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="4dp" />

                <!-- Rating Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:id="@+id/tv_tailor_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★ 4.8 (127)"
                        android:textColor="#F59E0B"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Location + Exp Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@android:drawable/ic_dialog_map"
                        app:tint="#94A3B8" />
                    <TextView
                        android:id="@+id/tv_tailor_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Colombo • 8 yrs exp"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginStart="2dp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Thin Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginBottom="12dp" />

        <!-- Specialty Badges + Price Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Badges -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_badge1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_white_pill"
                    android:backgroundTint="#EFF6FF"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="Dresses"
                    android:textColor="#2563EB"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_badge2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_white_pill"
                    android:backgroundTint="#F0FDF4"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="Formal Wear"
                    android:textColor="#16A34A"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Price -->
            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From Rs. 35"
                android:textColor="#1E3A8A"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
