<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Message bubble received -->
    <LinearLayout
        android:id="@+id/layout_received"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:layout_marginEnd="64dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_received"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:id="@+id/iv_received_image"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="4dp"
                android:clipToOutline="true"
                android:visibility="gone" />

            <!-- Voice Message UI Received -->
            <LinearLayout
                android:id="@+id/layout_received_voice"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp"
                android:visibility="gone">
                <ImageButton
                    android:id="@+id/btn_play_received"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_primary"
                    android:backgroundTint="@color/primary"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/white"
                    android:padding="8dp" />
                <SeekBar
                    android:id="@+id/seekbar_received"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="@color/primary"
                    android:thumbTint="@color/primary" />
                <TextView
                    android:id="@+id/tv_received_voice_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#64748B"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_received_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Received message"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Message bubble sent -->
    <LinearLayout
        android:id="@+id/layout_sent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/bg_bubble_sent"
        android:elevation="1dp"
        android:orientation="vertical"
        android:padding="6dp"
        android:layout_marginStart="64dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_sent_image"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="4dp"
            android:clipToOutline="true"
            android:visibility="gone" />

        <!-- Voice Message UI Sent -->
        <LinearLayout
            android:id="@+id/layout_sent_voice"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp"
            android:visibility="gone">
            <ImageButton
                android:id="@+id/btn_play_sent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_primary"
                android:backgroundTint="@color/primary"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/white"
                android:padding="8dp" />
            <SeekBar
                android:id="@+id/seekbar_sent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />
            <TextView
                android:id="@+id/tv_sent_voice_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#64748B"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_gravity="end">

            <TextView
                android:id="@+id/tv_sent_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sent message"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:layout_marginEnd="6dp"
                android:layout_marginStart="4dp" />

            <TextView
                android:id="@+id/tv_ticks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓✓"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
