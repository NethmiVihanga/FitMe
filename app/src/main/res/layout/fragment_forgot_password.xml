<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="40dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_primary"
            android:backgroundTint="@color/primary"
            android:src="@drawable/ic_back_chevron"
            app:tint="@color/white"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Forgot Password"
            android:textColor="@color/text_header"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Enter your registered email to reset your password."
        android:textColor="@color/text_header"
        android:textSize="14sp"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:paddingHorizontal="24dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#8AA8E8"
        app:cardElevation="0dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input_white"
                android:fontFamily="serif"
                android:hint="Email Address"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_header"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_reset"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/bg_white_pill"
        android:backgroundTint="@color/primary"
        android:fontFamily="serif"
        android:text="Continue to Reset"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:elevation="4dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#EF4444"
        android:textSize="12sp"
        android:visibility="gone"
        android:textStyle="bold" />

</LinearLayout>
